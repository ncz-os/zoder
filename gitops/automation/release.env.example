# Per-host release/pull settings. Copy to ~/.config/zoder/release.env.
# CLASS is usually auto-detected; set explicitly to be safe.

CLASS=                       # zoder  (blank = auto-detect)
CHANNEL=stable               # stable | edge

# Where published binaries live. The puller fetches:
#   $RELEASE_BASE_URL/$CHANNEL/<bin>-<target-triple>
# Example (public GitLab release assets):
#   https://gitlab.com/ncz-os/zoder/-/releases/permalink/latest/downloads
RELEASE_BASE_URL=

INSTALL_PREFIX=$HOME/.local/bin
